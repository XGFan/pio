{
  "manifest_version": 3,
  "name": "PIO Proxy Switcher",
  "version": "1.0.0",
  "description": "Add a PIO subscription URL, pick a proxy, and apply it browser-wide.",
  "minimum_chrome_version": "108",
  "permissions": [
    "proxy",
    "storage",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "PIO Proxy Switcher",
    "default_popup": "popup.html"
  }
}
